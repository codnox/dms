              </div>
              <div>
                <h3 className="font-semibold text-gray-800">Quick Scan</h3>
                <p className="text-sm text-gray-500">Scan barcode or paste device label text</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <Zap className="w-4 h-4 text-yellow-500" />
              <span className="text-xs text-gray-500">Auto-detect enabled</span>
            </div>
          </div>

          <div className="relative">
            <textarea
              ref={scanInputRef}
              value={scanInput}
              onChange={handleTextAreaScan}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && !e.shiftKey && scanInput.length > 5) {
                  e.preventDefault();
                  processScan(scanInput);
                }
              }}
              placeholder="Scan barcode here or paste/type device information...

Examples:
• MAC: 64FB9265062B
• Model: SI5520GWV  
• PON SN: SCPS550FBC00
• ONT S/N: SC202308170108

You can paste multiple lines from the device label!"
              className="w-full h-32 px-4 py-3 border-2 border-blue-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm bg-white placeholder-gray-400 resize-none"
              autoFocus
            />
            {scanInput && (
              <button
                type="button"
                onClick={() => {
                  setScanInput('');
                  setParsedPreview(null);
                }}
                className="absolute top-2 right-2 p-1 text-gray-400 hover:text-gray-600"
              >
                <X className="w-4 h-4" />
              </button>
            )}
          </div>

          {/* Parsed Preview */}
          {parsedPreview && parsedPreview.detectedFields.length > 0 && (
            <div className="bg-white rounded-lg border border-green-200 p-4 space-y-3">
              <div className="flex items-center gap-2 text-green-700">
                <CheckCircle className="w-5 h-5" />
                <span className="font-medium">Detected {parsedPreview.detectedFields.length} field(s)</span>
              </div>
              
              <div className="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
                {parsedPreview.macAddress && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">MAC Address</span>
                    <p className="font-mono font-medium text-gray-800">{parsedPreview.macAddress}</p>
                  </div>
                )}
                {parsedPreview.serialNumber && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">Serial Number</span>
                    <p className="font-mono font-medium text-gray-800">{parsedPreview.serialNumber}</p>
                  </div>
                )}
                {parsedPreview.ponSerialNumber && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">PON Serial</span>
                    <p className="font-mono font-medium text-gray-800">{parsedPreview.ponSerialNumber}</p>
                  </div>
                )}
                {parsedPreview.ontSerialNumber && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">ONT Serial</span>
                    <p className="font-mono font-medium text-gray-800">{parsedPreview.ontSerialNumber}</p>
                  </div>
                )}
                {parsedPreview.model && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">Model</span>
                    <p className="font-medium text-gray-800">{parsedPreview.model}</p>
                  </div>
                )}
                {parsedPreview.manufacturer && (
                  <div className="bg-gray-50 rounded p-2">
                    <span className="text-gray-500 text-xs">Manufacturer</span>
                    <p className="font-medium text-gray-800">{parsedPreview.manufacturer}</p>
                  </div>
                )}
              </div>

              <div className="flex justify-end">
                <Button onClick={applyParsedData} icon={batchMode ? Plus : CheckCircle} size="sm">
                  {batchMode ? 'Add to Batch' : 'Apply & Continue'}
                </Button>
              </div>
            </div>
          )}

          {/* No detection warning */}
          {scanInput.length > 10 && (!parsedPreview || parsedPreview.detectedFields.length === 0) && (
            <div className="flex items-center gap-2 text-amber-600 bg-amber-50 rounded-lg p-3">
              <AlertCircle className="w-5 h-5" />
              <span className="text-sm">Could not auto-detect fields. Please enter manually below.</span>
            </div>
          )}
        </div>
      </Card>

      {/* Batch Preview */}
      {batchMode && batchDevices.length > 0 && (
        <Card>
          <div className="flex items-center justify-between mb-4">
            <h3 className="font-semibold text-gray-800">Batch Queue ({batchDevices.length} devices)</h3>
            <div className="flex gap-2">
              <Button variant="secondary" size="sm" onClick={clearBatch} icon={Trash2}>
                Clear All
              </Button>
              <Button onClick={handleBatchSubmit} loading={loading} icon={Save} size="sm">
                Register All
              </Button>
            </div>
          </div>
          
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead className="bg-gray-50">
                <tr>
                  <th className="px-3 py-2 text-left text-gray-600">MAC Address</th>
                  <th className="px-3 py-2 text-left text-gray-600">Serial Number</th>
                  <th className="px-3 py-2 text-left text-gray-600">Model</th>
                  <th className="px-3 py-2 text-left text-gray-600">Manufacturer</th>
                  <th className="px-3 py-2 text-left text-gray-600">Action</th>
                </tr>
              </thead>
              <tbody className="divide-y">
                {batchDevices.map((device, index) => (
                  <tr key={device.id} className="hover:bg-gray-50">
                    <td className="px-3 py-2 font-mono text-xs">{device.macAddress}</td>
                    <td className="px-3 py-2 font-mono text-xs">{device.serialNumber || device.ontSerialNumber}</td>
                    <td className="px-3 py-2">{device.model}</td>
                    <td className="px-3 py-2">{device.manufacturer}</td>
                    <td className="px-3 py-2">
                      <button
                        onClick={() => removeFromBatch(device.id)}
                        className="text-red-500 hover:text-red-700"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Card>
      )}

      {/* Manual Entry Form */}
      {!batchMode && (
        <Card>
          <form onSubmit={handleSubmit} className="space-y-6">
            <div className="flex items-center justify-between border-b border-gray-200 pb-4">
              <h3 className="font-semibold text-gray-800">Device Details</h3>
              <button
                type="button"
                onClick={() => setScanMode(!scanMode)}
                className="text-sm text-blue-600 hover:text-blue-700"
              >
                {scanMode ? 'Hide scanner' : 'Show scanner'}
              </button>
            </div>
            
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Device Type <span className="text-red-500">*</span>
                </label>
                <select
                  name="deviceType"
                  value={formData.deviceType}
                  onChange={handleChange}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  required
                >
                  <option value="ONT">ONT</option>
                  <option value="ONU">ONU</option>
                  <option value="Router">Router</option>
                  <option value="Switch">Switch</option>
                  <option value="Modem">Modem</option>
                  <option value="Access Point">Access Point</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  MAC Address <span className="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="macAddress"
                  value={formData.macAddress}
                  onChange={(e) => {
                    const formatted = formatMACAddress(e.target.value);
                    setFormData(prev => ({ ...prev, macAddress: formatted }));
                  }}
                  placeholder="AA:BB:CC:DD:EE:FF"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono"
                  required
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Serial Number <span className="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="serialNumber"
                  value={formData.serialNumber}
                  onChange={handleChange}
                  placeholder="Device serial number"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono"
                  required
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  PON Serial Number
                </label>
                <input
                  type="text"
                  name="ponSerialNumber"
                  value={formData.ponSerialNumber}
                  onChange={handleChange}
                  placeholder="PON S/N (if applicable)"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  ONT Serial Number
                </label>
                <input
                  type="text"
                  name="ontSerialNumber"
                  value={formData.ontSerialNumber}
                  onChange={handleChange}
                  placeholder="ONT S/N (if applicable)"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Device Model <span className="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="model"
                  value={formData.model}
                  onChange={handleChange}
                  placeholder="e.g., SI5520GWV, STREAM 1K14F"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  required
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Manufacturer <span className="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="manufacturer"
                  value={formData.manufacturer}
                  onChange={handleChange}
                  placeholder="e.g., Syrotech, PPC Technologies"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  required
                  list="manufacturers"
                />
                <datalist id="manufacturers">
                  <option value="Syrotech" />
                  <option value="PPC Technologies" />
                  <option value="VSOL" />
                  <option value="Huawei" />
                  <option value="ZTE" />
                  <option value="Nokia" />
                  <option value="Fiberhome" />
                  <option value="HFCL" />
                  <option value="Netlink" />
                  <option value="DBC" />
                </datalist>
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Part Number
                </label>
                <input
                  type="text"
                  name="partNumber"
                  value={formData.partNumber}
                  onChange={handleChange}
                  placeholder="Part number (if available)"
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Certificate Number
                </label>
                <input
                  type="text"
                  name="certificateNo"
                  value={formData.certificateNo}
                  onChange={handleChange}
                  placeholder="TEC Certificate No."
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Condition <span className="text-red-500">*</span>
                </label>
                <select
                  name="condition"
                  value={formData.condition}
                  onChange={handleChange}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  required
                >
                  <option value="new">New</option>
                  <option value="refurbished">Refurbished</option>
                </select>
              </div>
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Additional Notes
              </label>
              <textarea
                name="notes"
                value={formData.notes}
                onChange={handleChange}
                rows={3}
                placeholder="Any additional information about the device..."
                className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              />
            </div>

            <div className="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
              <Button variant="secondary" onClick={() => navigate('/devices')} icon={X}>
                Cancel
              </Button>
              <Button type="submit" loading={loading} icon={Save}>
                Register Device
              </Button>
            </div>
          </form>
        </Card>
      )}

      {/* Tips Card */}
      <Card className="bg-gray-50 border-gray-200">
        <h4 className="font-medium text-gray-700 mb-2">💡 Scanning Tips</h4>
        <ul className="text-sm text-gray-600 space-y-1">
          <li>• <strong>Barcode Scanner:</strong> Just scan - data auto-fills instantly</li>
          <li>• <strong>Manual Entry:</strong> Paste text from device label for auto-detection</li>
          <li>• <strong>Batch Mode:</strong> Enable to register multiple devices quickly</li>
          <li>• <strong>Supported formats:</strong> MAC, PON S/N, ONT S/N, Model, Part Number</li>
        </ul>
      </Card>
    </div>
  );
};

export default RegisterDevice;
